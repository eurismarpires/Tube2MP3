<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{A131B4E3-62DF-4B25-9C7E-312112B7049A}</ProjectGuid>
    <ProjectVersion>18.6</ProjectVersion>
    <FrameworkType>VCL</FrameworkType>
    <MainSource>Tube2MP3.dpr</MainSource>
    <Config Condition="'$(Config)'==''">Debug</Config>
    <Platform Condition="'$(Platform)'==''">Win32</Platform>
    <TargetedPlatforms>1</TargetedPlatforms>
    <AppType>Application</AppType>
  </PropertyGroup>
  <PropertyGroup>
    <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Winapi;Vcl;FireDAC;$(DCC_Namespace)</DCC_Namespace>
    <DCC_DcuOutput>.\build\$(Platform)\$(Config)\dcu</DCC_DcuOutput>
    <DCC_ExeOutput>.</DCC_ExeOutput>
    <SanitizedProjectName>Tube2MP3</SanitizedProjectName>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Debug'">
    <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
    <DCC_DebugInformation>2</DCC_DebugInformation>
    <DCC_LocalDebugSymbols>true</DCC_LocalDebugSymbols>
    <DCC_Optimization>false</DCC_Optimization>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Release'">
    <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
    <DCC_DebugInformation>0</DCC_DebugInformation>
    <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
    <DCC_Optimization>true</DCC_Optimization>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Platform)'=='Win32'">
    <DCC_ExeOutput>.</DCC_ExeOutput>
    <DCC_DcuOutput>.\build\Win32\$(Config)\dcu</DCC_DcuOutput>
    <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
    <VerInfo_Locale>1046</VerInfo_Locale>
  </PropertyGroup>
  <ItemGroup>
    <DelphiCompile Include="$(MainSource)">
      <MainSource>MainSource</MainSource>
    </DelphiCompile>
    <DCCReference Include="src\Presentation\Tube2MP3.Presentation.Main.pas">
      <Form>MainForm</Form>
    </DCCReference>
    <DCCReference Include="src\Domain\Tube2MP3.Domain.Models.pas"/>
    <DCCReference Include="src\Application\Tube2MP3.Application.Helpers.pas"/>
    <DCCReference Include="src\Infrastructure\Tube2MP3.Infrastructure.Logger.pas"/>
    <DCCReference Include="src\Infrastructure\Tube2MP3.Infrastructure.Settings.pas"/>
    <DCCReference Include="src\Infrastructure\Tube2MP3.Infrastructure.History.pas"/>
    <DCCReference Include="src\Infrastructure\Tube2MP3.Infrastructure.ProcessRunner.pas"/>
    <DCCReference Include="src\Infrastructure\Tube2MP3.Infrastructure.YtDlp.pas"/>
    <BuildConfiguration Include="Debug">
      <Key>Cfg_2</Key>
      <CfgParent>Base</CfgParent>
    </BuildConfiguration>
    <BuildConfiguration Include="Release">
      <Key>Cfg_1</Key>
      <CfgParent>Base</CfgParent>
    </BuildConfiguration>
  </ItemGroup>
  <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
  <ProjectExtensions>
    <Borland.Personality>Delphi.Personality.12</Borland.Personality>
    <Borland.ProjectType>VCLApplication</Borland.ProjectType>
  </ProjectExtensions>
</Project>
